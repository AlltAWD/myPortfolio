---
import Layout from '../layouts/Layout.astro';
import { getEntry } from 'astro:content';
import { BookOpen, Code, Search, ArrowLeft, Clock } from 'lucide-solid';

const lang = Astro.currentLocale || 'en-US';
let statusEntry = await getEntry('status', `${lang}/index`);
if (!statusEntry && lang !== 'en-US') {
  statusEntry = await getEntry('status', `en-US/index`);
}
const statusData = statusEntry?.data || { learning: [], building: [], research: [] };

// Helper to calculate "time ago" string from YYYY-MM-DD
function timeAgo(dateString: string) {
  if (!dateString) return 'recently';
  const date = new Date(dateString);
  const now = new Date();
  const diffTime = Math.abs(now.getTime() - date.getTime());
  const diffDays = Math.ceil(diffTime / (1000 * 60 * 60 * 24));
  
  if (diffDays === 0) return 'today';
  if (diffDays === 1) return 'yesterday';
  if (diffDays < 7) return `${diffDays} days ago`;
  if (diffDays < 30) return `${Math.floor(diffDays / 7)} weeks ago`;
  if (diffDays < 365) return `${Math.floor(diffDays / 30)} months ago`;
  return `${Math.floor(diffDays / 365)} years ago`;
}

const colorMap: Record<string, string> = {
  purple: 'purple-500',
  muted: '[var(--muted)]',
  blue: 'blue-500',
  emerald: 'emerald-500'
};
---

<Layout title="Status Detail | Hanson Liu">
  <main class="pt-32 pb-16 px-4">
    <div class="max-w-4xl mx-auto">
      <a href="/" class="inline-flex items-center gap-2 text-[var(--muted-foreground)] hover:text-[var(--foreground)] mb-8 transition-colors">
        <ArrowLeft class="w-4 h-4" />
        Back to Home
      </a>

      <h1 class="text-4xl font-bold mb-12">Detailed Status</h1>

      <!-- Learning Section -->
      <section id="learning" class="mb-16">
        <div class="flex items-center gap-4 mb-8">
          <div class="p-3 neu-pressed rounded-xl text-blue-500">
            <BookOpen class="w-8 h-8" />
          </div>
          <h2 class="text-3xl font-bold">Learning Path</h2>
        </div>

        <div class="neu-flat p-8 rounded-2xl space-y-8">
          {statusData.learning.map((item) => (
            <div>
              <div class="flex justify-between items-end mb-2">
                <h3 class="text-xl font-bold">{item.title}</h3>
                <span class="text-blue-500 font-bold">{item.progress}%</span>
              </div>
              <div class="h-4 bg-[var(--muted)] rounded-full overflow-hidden mb-2">
                <div class="h-full bg-blue-500 rounded-full" style={`width: ${item.progress}%`}></div>
              </div>
              <p class="text-[var(--muted-foreground)]">{item.description}</p>
              <div class="flex items-center gap-2 mt-3 text-sm text-[var(--muted-foreground)] opacity-70">
                <Clock class="w-4 h-4" />
                <span>Last updated: {timeAgo(item.lastUpdated)}</span>
              </div>
            </div>
          ))}
          {statusData.learning.length === 0 && <p class="text-[var(--muted-foreground)]">No active learning paths listed.</p>}
        </div>
      </section>

      <!-- Building Section -->
      <section id="building" class="mb-16">
        <div class="flex items-center gap-4 mb-8">
          <div class="p-3 neu-pressed rounded-xl text-emerald-500">
            <Code class="w-8 h-8" />
          </div>
          <h2 class="text-3xl font-bold">Active Builds</h2>
        </div>

        <div class="neu-flat p-8 rounded-2xl space-y-8">
          {statusData.building.map((item) => (
            <div>
              <div class="flex justify-between items-end mb-2">
                <h3 class="text-xl font-bold">{item.title}</h3>
                <span class="text-emerald-500 font-bold">{item.progress}%</span>
              </div>
              <div class="h-4 bg-[var(--muted)] rounded-full overflow-hidden mb-2">
                <div class="h-full bg-emerald-500 rounded-full" style={`width: ${item.progress}%`}></div>
              </div>
              {item.tasks && item.tasks.length > 0 && (
                <ul class="list-disc list-inside text-[var(--muted-foreground)] mt-4 space-y-1">
                  {item.tasks.map((task) => (
                    <li>{task}</li>
                  ))}
                </ul>
              )}
              <div class="flex items-center gap-2 mt-3 text-sm text-[var(--muted-foreground)] opacity-70">
                <Clock class="w-4 h-4" />
                <span>Last updated: {timeAgo(item.lastUpdated)}</span>
              </div>
            </div>
          ))}
          {statusData.building.length === 0 && <p class="text-[var(--muted-foreground)]">No active builds listed.</p>}
        </div>
      </section>

      <!-- Research Section -->
      <section id="research" class="mb-16">
        <div class="flex items-center gap-4 mb-8">
          <div class="p-3 neu-pressed rounded-xl text-purple-500">
            <Search class="w-8 h-8" />
          </div>
          <h2 class="text-3xl font-bold">Research Lab</h2>
        </div>

        <div class="neu-flat p-8 rounded-2xl space-y-8">
          {statusData.research.map((item) => {
            const isMuted = item.color === 'muted';
            const colorClass = colorMap[item.color] || 'purple-500';
            const borderClass = isMuted ? 'border-[var(--muted)] opacity-75' : `border-${colorClass}`;
            const bgClass = isMuted ? 'bg-[var(--muted)] text-[var(--muted-foreground)]' : `bg-${colorClass}/10 text-${colorClass}`;

            return (
              <div class={`border-l-4 ${borderClass} pl-6 py-2`}>
                <h3 class="text-xl font-bold mb-2">{item.title}</h3>
                <div class="flex gap-2 mb-4">
                  <span class={`px-3 py-1 ${bgClass} rounded-full text-sm font-bold`}>{item.phase}</span>
                </div>
                <p class="text-[var(--muted-foreground)]">{item.description}</p>
                <div class="flex items-center gap-2 mt-3 text-sm text-[var(--muted-foreground)] opacity-70">
                  <Clock class="w-4 h-4" />
                  <span>Last updated: {timeAgo(item.lastUpdated)}</span>
                </div>
              </div>
            );
          })}
          {statusData.research.length === 0 && <p class="text-[var(--muted-foreground)]">No active research listed.</p>}
        </div>
      </section>
    </div>
  </main>
</Layout>